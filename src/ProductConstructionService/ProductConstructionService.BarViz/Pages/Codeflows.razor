@page "/codeflows"

@using System.Linq.Expressions
@using System.Text
@using Microsoft.DotNet.ProductConstructionService.Client
@using Microsoft.DotNet.ProductConstructionService.Client.Models
@using Microsoft.FluentUI.AspNetCore.Components.Extensions
@using ProductConstructionService.BarViz.Code.Helpers
@using ProductConstructionService.BarViz.Components
@using ProductConstructionService.BarViz.Model
@inject NavigationManager NavManager
@inject IProductConstructionServiceApi PcsApi
@inject IDialogService DialogService

<style>
    .hover:not([row-type='header'],[row-type='sticky-header'],.loading-content-row):hover[b-upi3f9mbnn] {
        cursor: default;
    }

    body[data-theme="light"] .disabled-subscription, body[data-theme="system-light"] .disabled-subscription {
        background-color: #f1f1f1;
    }

    .disabled-subscription, .disabled-subscription .control, .disabled-subscription .fluent-typography {
        color: var(--neutral-foreground-hint) !important;
        font-style: italic;
    }

    .commitSha {
        border: none;
        color: #888;
        font-family: monospace;
        font-size: 0.8em;
        top: -4px;
        position: relative;
        margin-left: 5px;
        margin-right: 7px;
    }

    .commitSha a {
        height: 23px;
        padding: 2px 6px 0px 6px;
    }

    .status-dot {
        display: inline-block;
        width: 10px;
        height: 10px;
        border-radius: 50%;
        vertical-align: middle;
        margin-right: 4px;
    }

    .status-green {
        background-color: #2da44e;
    }

    .status-yellow {
        background-color: #d4a017;
    }

    .status-red {
        background-color: #cf222e;
    }

</style>

<PageTitle>Codeflows – Maestro++</PageTitle>

<GridViewTemplate Title="Codeflows" ShowSkeleton="CodeFlowRows == null">
    <Header>
        <FluentSelect TOption="DefaultChannel"
                      Items="@DefaultChannels"
                      OptionValue="@(channel => channel.Branch)"
                      OptionSelected="@(c => c.Id == _defaultChannel?.Id)"
                      SelectedOptionChanged="@(OnDefaultChannelSelected)"
                      SelectedOption="@_defaultChannel"
                      Immediate="true"
                      Multiple="false"
                      style="float: right">
            <OptionTemplate>
                <span title="Channel ID: @context.Channel.Id">@context.Branch / @context.Channel.Name</span>
            </OptionTemplate>
        </FluentSelect>
    </Header>
    <Content>
        <SubscriptionErrorBanner Errors="@SubscriptionErrors" />
        <FluentDataGrid Items="@CodeFlowRows"
                        AutoFit="true"
                        TGridItem=CodeflowRow
                        ResizableColumns="true"
                        ShowHover="true"
                        RowClass="@(row => row.Enabled ? null : "disabled-subscription")"
                        Style="width: 100%">
            <EmptyContent>
                <FluentLabel>No subscriptions found</FluentLabel>
            </EmptyContent>
            <ChildContent>
                <TemplateColumn Title="Repository" Sortable="true" SortBy="RowSortBy(r => r.MappingName)" Align="Align.Start">
                    <div style="display: flex; align-items: center;">
                        <span style="width: 20px; display: inline-flex; justify-content: center; flex: 0 0 auto;">
                            <SubscriptionOutcomeAlertIcon ForwardFlowOutcome="@context.ForwardFlow?.LatestOutcome" BackflowOutcome="@context.Backflow?.LatestOutcome" />
                        </span>
                        <FluentAnchor Href="@context.RepositoryUrl" Target="_blank" Appearance="Appearance.Hypertext">@context.MappingName</FluentAnchor>
                    </div>
                </TemplateColumn>
                <TemplateColumn Title="Forward flow channel" Sortable="true" SortBy="RowSortBy(r => r.ForwardFlowChannel)" Align="Align.Start">
                    <FluentLabel Title="The channel on which the subscription flows into the VMR.">@(context.ForwardFlowChannel ?? "—")</FluentLabel>
                </TemplateColumn>
                <TemplateColumn Title="Last forward flow build"
                                Sortable="true"
                                SortBy="@RowSortByDescending(r => r.ForwardFlow != null && r.ForwardFlow.Subscription != null && r.ForwardFlow.Subscription.LastAppliedBuild != null ? r.ForwardFlow.Subscription.LastAppliedBuild.DateProduced.ToString("o") : "1900")"
                                Align="Align.Start">
                    <FluentLabel Title="@(context.ForwardFlow?.Subscription?.LastAppliedBuild?.DateProduced.ToString("f"))">
                        @if (context.ForwardFlow?.Subscription?.LastAppliedBuild != null)
                        {
                            @(GetLastAppliedBuildTimeAgo(context.ForwardFlow.Subscription))
                            @if (context.ForwardFlow.Subscription.LastAppliedBuild.Staleness is > 0)
                            {
                                <span style="color: #888; font-size: 0.85em; margin-left: 4px;">
                                    (@GetBuildTimeStaleness(context.ForwardFlow))
                                </span>
                            }
                            else if (context.ForwardFlow.NewestBuildDate == null)
                            {
                                <span style="color: #888; margin-left: 4px;">—</span>
                            }
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </FluentLabel>
                </TemplateColumn>
                <TemplateColumn Title="Forward flow PR" Sortable="true" SortBy="@RowSortByDescending(r => r.ForwardFlow != null && r.ForwardFlow.ActivePullRequest != null ? r.ForwardFlow.ActivePullRequest.CreationDate.ToString("o") : "0")" Align="Align.Start">
                    @if (context.ForwardFlow?.ActivePullRequest != null)
                    {
                        <FluentLabel>
                            <span class="status-dot @GetPrStatusClass(context.ForwardFlow.ActivePullRequest)"></span>
                            <FluentAnchor Href="@context.ForwardFlow.ActivePullRequest.Url" Target="_blank" Appearance="Appearance.Hypertext">#@RepoUrlConverter.GetPrNumber(context.ForwardFlow.ActivePullRequest.Url) (@GetPrAge(context.ForwardFlow.ActivePullRequest))</FluentAnchor>
                        </FluentLabel>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </TemplateColumn>
                <TemplateColumn Title="Backflow branch" Sortable="true" SortBy="RowSortBy(r => r.BackflowBranch)" Align="Align.Start">
                    <FluentLabel Title="The repository branch that changes from the VMR flow into.">@(context.BackflowBranch ?? "—")</FluentLabel>
                </TemplateColumn>
                <TemplateColumn Title="Last backflow build"
                                Sortable="true"
                                SortBy="@RowSortByDescending(r => r.Backflow != null && r.Backflow.Subscription != null && r.Backflow.Subscription.LastAppliedBuild != null ? r.Backflow.Subscription.LastAppliedBuild.DateProduced.ToString("o") : "1900")"
                                Align="Align.Start">
                    <FluentLabel Title="@(context.Backflow?.Subscription?.LastAppliedBuild?.DateProduced.ToString("f"))">
                        @if (context.Backflow?.Subscription?.LastAppliedBuild != null)
                        {
                            @(GetLastAppliedBuildTimeAgo(context.Backflow.Subscription))
                            @if (context.Backflow.Subscription.LastAppliedBuild.Staleness is > 0)
                            {
                                <span style="color: #888; font-size: 0.85em; margin-left: 4px;">
                                    (@GetBuildTimeStaleness(context.Backflow))
                                </span>
                            }
                            else if (context.Backflow.NewestBuildDate == null)
                            {
                                <span style="color: #888; margin-left: 4px;">—</span>
                            }
                        }
                        else
                        {
                            <span>—</span>
                        }
                    </FluentLabel>
                </TemplateColumn>
                <TemplateColumn Title="Backflow PR" Sortable="true" SortBy="@RowSortByDescending(r => r.Backflow != null && r.Backflow.ActivePullRequest != null ? r.Backflow.ActivePullRequest.CreationDate.ToString("o") : "0")" Align="Align.Start">
                    @if (context.Backflow?.ActivePullRequest != null)
                    {
                        <FluentLabel>
                            <span class="status-dot @GetPrStatusClass(context.Backflow.ActivePullRequest)"></span>
                            <FluentAnchor Href="@context.Backflow.ActivePullRequest.Url" Target="_blank" Appearance="Appearance.Hypertext">#@RepoUrlConverter.GetPrNumber(context.Backflow.ActivePullRequest.Url) (@GetPrAge(context.Backflow.ActivePullRequest))</FluentAnchor>
                        </FluentLabel>
                    }
                    else
                    {
                        <span>—</span>
                    }
                </TemplateColumn>
                <TemplateColumn Width="60px">
                    <CodeflowContextMenu Codeflow="@ToCodeflowSubscription(context)" ShowDetails="@ShowDetails" />
                </TemplateColumn>
            </ChildContent>
        </FluentDataGrid>
    </Content>
</GridViewTemplate>


@code {
    [SupplyParameterFromQuery(Name = "branch")]
    private string? branchQuery { get; set; }

    IQueryable<CodeflowRow>? CodeFlowRows;

    private IReadOnlyList<SubscriptionOutcomeError> SubscriptionErrors = [];

    private DefaultChannel? _defaultChannel = null;

    private string _branch = "main";

    private List<DefaultChannel> DefaultChannels = [];

    GridSort<CodeflowRow> RowSortBy(Expression<Func<CodeflowRow, string?>> sorter)
        => GridSort<CodeflowRow>.ByAscending(sorter);

    GridSort<CodeflowRow> RowSortByDescending(Expression<Func<CodeflowRow, string?>> sorter)
        => GridSort<CodeflowRow>.ByDescending(sorter);

    private const string DefaultVmrUrl = "https://github.com/dotnet/dotnet";

    protected override async Task OnInitializedAsync()
    {
        CodeFlowRows = null;
        _branch = branchQuery ?? "main";

        var optimisticStatusTask = TryLoadCodeflowStatusesAsync(_branch, DefaultVmrUrl);
        var defaultChannelsTask = GetDefaultChannelsAsync();

        await Task.WhenAll(optimisticStatusTask, defaultChannelsTask);

        var optimisticStatuses = optimisticStatusTask.Result;
        DefaultChannels = defaultChannelsTask.Result;

        if (!string.IsNullOrEmpty(branchQuery))
        {
            _defaultChannel = DefaultChannels.FirstOrDefault(c => c.Branch == branchQuery);
        }

        if (_defaultChannel == null)
        {
            _defaultChannel = DefaultChannels.FirstOrDefault(c => c.Branch == "main");
        }

        if (optimisticStatuses != null)
        {
            SetRows(optimisticStatuses);
        }
        else
        {
            _branch = _defaultChannel?.Branch ?? "main";
            await LoadCodeflowStatusesAsync();
        }
    }

    async Task<IList<CodeflowStatus>?> TryLoadCodeflowStatusesAsync(string branch, string repositoryUrl)
    {
        try
        {
            return await PcsApi.Codeflow.GetCodeflowStatusesAsync(
                branch: branch,
                repositoryUrl: repositoryUrl);
        }
        catch
        {
            return null;
        }
    }

    async Task LoadCodeflowStatusesAsync()
    {
        if (_defaultChannel == null)
        {
            CodeFlowRows = Array.Empty<CodeflowRow>().AsQueryable();
            SubscriptionErrors = [];
            return;
        }

        var statuses = await PcsApi.Codeflow.GetCodeflowStatusesAsync(
            branch: _branch,
            repositoryUrl: _defaultChannel.Repository);

        SetRows(statuses);
    }

    void SetRows(IList<CodeflowStatus> statuses)
    {
        var rows = ToRows(statuses);
        CodeFlowRows = rows.AsQueryable();
        SubscriptionErrors = SubscriptionOutcomeHelper.GetErroredSubscriptions(
            rows.SelectMany(r => new CodeflowSubscriptionStatus?[] { r.ForwardFlow, r.Backflow }));
    }

    async Task OnDefaultChannelSelected(DefaultChannel channel)
    {
        _defaultChannel = channel;
        _branch = channel.Branch;
        UpdateQueryParams();
        await LoadCodeflowStatusesAsync();
    }

    private void UpdateQueryParams()
    {
        var newUri = NavManager.GetUriWithQueryParameters(new Dictionary<string, object?>
        {
            ["branch"] = _branch
        });

        NavManager.NavigateTo(newUri);
    }

    async Task ShowDetails(Subscription subscription)
    {
        if (subscription == null) return;

        DialogParameters parameters = new()
        {
            Title = $"Subscription {subscription.Id}",
            Width = "800px",
            TrapFocus = true,
            Modal = true,
            PreventScroll = true,
            PrimaryAction = null,
            SecondaryAction = "Close",
        };

        await DialogService.ShowDialogAsync<SubscriptionDetailDialog>(SubscriptionDetailData.FromSubscription(subscription), parameters);
    }

    async Task<List<DefaultChannel>> GetDefaultChannelsAsync()
    {
        string[] possibleVmrs =
        [
            "https://github.com/dotnet/dotnet",
            "https://github.com/maestro-auth-test/dotnet",
            "https://github.com/maestro-auth-test/dnceng-vmr",
    ];

        foreach (var vmrUri in possibleVmrs)
        {
            var defaultChannels = await PcsApi.DefaultChannels.ListAsync(repository: vmrUri);

            if (defaultChannels.Count > 0)
            {
                return defaultChannels
                    .OrderByDescending(c => c.Branch == "main")
                    .ThenByDescending(c => c.Branch)
                    .ToList();
            }
        }

        return
        [
            new DefaultChannel(0, string.Empty, true)
            {
                Branch = "No VMR",
                Channel = new Microsoft.DotNet.ProductConstructionService.Client.Models.Channel(0, "codeflows found", string.Empty),
            }
        ];
    }

    string GetLastAppliedBuildTimeAgo(Subscription? subscription)
    {
        return subscription?.LastAppliedBuild != null
            ? (DateTime.UtcNow - subscription.LastAppliedBuild.DateProduced).ToTimeAgo()
            : "—";
    }

    static List<CodeflowRow> ToRows(IList<CodeflowStatus> statuses)
    {
        var rows = new List<CodeflowRow>();

        foreach (var status in statuses.OrderBy(s => s.MappingName))
        {
            bool enabled = (status.Backflow?.Subscription?.Enabled ?? false)
                || (status.ForwardFlow?.Subscription?.Enabled ?? false);

            rows.Add(new CodeflowRow(
                MappingName: status.MappingName,
                RepositoryUrl: status.RepositoryUrl,
                RepositoryBranch: status.RepositoryBranch,
                ForwardFlowChannel: status.ForwardFlow?.Subscription?.Channel?.Name,
                BackflowBranch: status.Backflow?.Subscription?.TargetBranch,
                ForwardFlow: status.ForwardFlow,
                Backflow: status.Backflow,
                Enabled: enabled));
        }

        return rows;
    }

    static CodeflowSubscription ToCodeflowSubscription(CodeflowRow row)
    {
        var forwardPr = row.ForwardFlow?.ActivePullRequest != null
            ? new ActivePullRequest(row.ForwardFlow.ActivePullRequest.CreationDate.UtcDateTime, row.ForwardFlow.ActivePullRequest.Url)
            : null;

        var backflowPr = row.Backflow?.ActivePullRequest != null
            ? new ActivePullRequest(row.Backflow.ActivePullRequest.CreationDate.UtcDateTime, row.Backflow.ActivePullRequest.Url)
            : null;

        return new CodeflowSubscription(
            RepositoryUrl: row.RepositoryUrl,
            RepositoryBranch: row.RepositoryBranch,
            MappingName: row.MappingName,
            Enabled: row.Enabled,
            BackflowSubscription: row.Backflow?.Subscription,
            ForwardflowSubscription: row.ForwardFlow?.Subscription,
            BackflowPr: backflowPr,
            ForwardflowPr: forwardPr);
    }

    static string GetPrAge(TrackedPullRequest pr)
    {
        if (pr == null || pr.CreationDate <= DateTimeOffset.UnixEpoch)
        {
            return "PR age not available";
        }

        var age = (DateTime.UtcNow - pr.CreationDate).ToTimeAgo();
        return age.Replace(" ago", " old");
    }

    static string GetBuildTimeStaleness(CodeflowSubscriptionStatus status)
    {
        var staleness = status?.Subscription?.LastAppliedBuild?.Staleness ?? 0;
        var buildWord = staleness == 1 ? "build" : "builds";

        if (status?.Subscription?.LastAppliedBuild?.DateProduced == null
            || status?.Subscription?.LastAppliedBuild?.DateProduced < DateTimeOffset.UnixEpoch
            || status?.NewestBuildDate == null
            || status.NewestBuildDate < DateTimeOffset.UnixEpoch)
        {
            return $"{staleness} {buildWord} behind newest build";
        }

        var age = ((DateTimeOffset)status.NewestBuildDate - status.Subscription.LastAppliedBuild.DateProduced).ToTimeAgo();

        return $"{staleness} {buildWord} and {age.Replace(" ago", "")} behind newest build";
    }

    /// <summary>
    /// Returns a CSS class for the PR age traffic light.
    /// Green: less than 3 days old.
    /// Yellow: less than 7 days old.
    /// Red: 7 days or older.
    /// </summary>
    static string GetPrStatusClass(TrackedPullRequest? pr)
    {
        if (pr == null || pr.CreationDate == DateTimeOffset.UnixEpoch)
        {
            return "";
        }

        double ageDays = (DateTime.UtcNow - pr.CreationDate).TotalDays;

        if (ageDays < 3)
        {
            return "status-green";
        }

        if (ageDays < 7)
        {
            return "status-yellow";
        }

        return "status-red";
    }

    record CodeflowRow(
        string MappingName,
        string RepositoryUrl,
        string? RepositoryBranch,
        string? ForwardFlowChannel,
        string? BackflowBranch,
        CodeflowSubscriptionStatus? ForwardFlow,
        CodeflowSubscriptionStatus? Backflow,
        bool Enabled);
}
