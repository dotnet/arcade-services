<Project>

  <!--
    This targets file copies the shared appsettings files from the BuildInsights root
    (src/BuildInsights/) to the output directory of consuming projects.
    Import this file from any project that needs shared BuildInsights configuration.

    Usage in consuming csproj:
      <Import Project="..\BuildInsights.ServiceDefaults\SharedConfiguration.targets" />
  -->

  <ItemGroup>
    <Content Include="$(MSBuildThisFileDirectory)..\appsettings.Shared*.json"
             Link="%(Filename)%(Extension)"
             CopyToOutputDirectory="PreserveNewest"
             CopyToPublishDirectory="PreserveNewest" />
  </ItemGroup>

</Project>
