<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="..\..\src\BuildInsights\BuildInsights.ServiceDefaults\SharedConfiguration.targets" />

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>true</IsPackable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>bi-webhook-tunnel</ToolCommandName>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Azure.Identity" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\BuildInsights\BuildInsights.ServiceDefaults\BuildInsights.ServiceDefaults.csproj" />
    <ProjectReference Include="..\..\src\Maestro\Maestro.Common\Maestro.Common.csproj" />
    <ProjectReference Include="..\..\src\Maestro\Maestro.Services.Common\Maestro.Services.Common.csproj" />
    <ProjectReference Include="..\..\src\Microsoft.DotNet.Darc\DarcLib\Microsoft.DotNet.DarcLib.csproj" />
  </ItemGroup>

  <ItemGroup>
    <None Update="appsettings*.json">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
      <CopyToPublishDirectory>PreserveNewest</CopyToPublishDirectory>
    </None>
  </ItemGroup>

</Project>
